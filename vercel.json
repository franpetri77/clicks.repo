{
  "rewrites": [
    { "source": "/admin",         "destination": "/index.html" },
    { "source": "/admin/caja",    "destination": "/caja.html" },
    { "source": "/admin/cocina",  "destination": "/cocina.html" },
    { "source": "/admin/login",   "destination": "/admin-login.html" },
    { "source": "/ticket",        "destination": "/ticket-cocina.html" },
    { "source": "/",              "destination": "/pedidos.html" }
  ],
  "redirects": [
    { "source": "/pedidos",             "destination": "/",              "permanent": false },
    { "source": "/menu",                "destination": "/",              "permanent": false },
    { "source": "/pedidos.html",        "destination": "/",              "permanent": false },
    { "source": "/caja.html",           "destination": "/admin/caja",    "permanent": false },
    { "source": "/cocina.html",         "destination": "/admin/cocina",  "permanent": false },
    { "source": "/index.html",          "destination": "/admin",         "permanent": false },
    { "source": "/admin-login.html",    "destination": "/admin/login",   "permanent": false },
    { "source": "/ticket-cocina.html",  "destination": "/ticket",        "permanent": false }
  ],
  "functions": {
    "api/*.js": {
      "runtime": "nodejs20.x"
    }
  }
}
